{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/tauri/tauri.conf.json",
  "productName": "DailyUp",
  "version": "0.1.0",
  "identifier": "com.dailyup.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost https: http:; img-src 'self' https://api.dicebear.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:"
    },
    "windows": [
      {
        "title": "DailyUp",
        "width": 1100,
        "height": 750,
        "minWidth": 380,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ]
  }
}
